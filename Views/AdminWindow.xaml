<Window x:Class="SupportServiceApp.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Администрирование" Height="450" Width="600">
    <Grid>
        <TabControl>
            <!-- Вкладка Клиенты -->
            <TabItem Header="Клиенты">
                <StackPanel Margin="10">
                    <TextBox Name="ClientTextBox" Text="Введите имя клиента" Margin="0,0,0,10"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                    <Button Content="Добавить клиента" Click="AddClient_Click" Margin="0,0,0,10"/>
                    <ListBox Name="ClientsListBox" Height="200" DisplayMemberPath="Name"/>
                    <Button Content="Удалить выбранного клиента" Click="DeleteClient_Click" Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка Оборудование -->
            <TabItem Header="Оборудование">
                <StackPanel Margin="10">
                    <TextBox Name="EquipmentTextBox" Text="Введите название оборудования" Margin="0,0,0,10"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                    <Button Content="Добавить оборудование" Click="AddEquipment_Click" Margin="0,0,0,10"/>
                    <ListBox Name="EquipmentListBox" Height="200" DisplayMemberPath="Name"/>
                    <Button Content="Удалить выбранное оборудование" Click="DeleteEquipment_Click" Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка Категории -->
            <TabItem Header="Категории">
                <StackPanel Margin="10">
                    <TextBox Name="CategoryTextBox" Text="Введите категорию" Margin="0,0,0,10"
                             GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                    <Button Content="Добавить категорию" Click="AddCategory_Click" Margin="0,0,0,10"/>
                    <ListBox Name="CategoryListBox" Height="200" DisplayMemberPath="Name"/>
                    <Button Content="Удалить выбранную категорию" Click="DeleteCategory_Click" Margin="0,10,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>